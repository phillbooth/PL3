{
    "name": "LO-app",
    "version": "0.1.0",
    "description": "A clean LO app workspace template.",
    "packages": [
        "packages/LO",
        "packages/app"
    ],
    "defaultPackage": "packages/app",
    "languagePackage": "packages/LO",
    "strict": true,
    "targets": [
        "cpu",
        "wasm",
        "ternary-sim"
    ],
    "docs": {
