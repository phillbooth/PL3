benchmark {
  default_mode "light"
  max_duration 180s
  run_on_major_update true
  allow_submit false

  targets {
    cpu true
    vector true
    gpu optional
    low_bit_ai optional
  }

  privacy {
    include_hostname false
    include_username false
    include_project_path false
    anonymise_cpu_model true
  }
}
