{
  "name": "@LO/language",
  "version": "0.1.0",
  "description": "LO / Logic Omni language package, examples, schemas and prototype CLI.",
  "license": "Apache-2.0",
  "type": "commonjs",
  "bin": {
    "LO": "./compiler/LO.js"
  },
  "scripts": {
    "check": "node compiler/LO.js check examples --exclude source-map-error.lo",
    "build:examples": "node compiler/LO.js build examples --exclude source-map-error.lo --out build/examples",
    "ast": "node compiler/LO.js ast examples/hello.lo",
    "tokens": "node compiler/LO.js tokens examples/hello.lo",
    "fmt": "node compiler/LO.js fmt examples",
    "fmt:check": "node compiler/LO.js fmt examples --check",
    "test": "node compiler/LO.js test examples",
    "generate:dev": "node compiler/LO.js generate examples --exclude source-map-error.lo --out .build-dev",
    "dev": "node compiler/LO.js dev examples/hello.lo --out .build-dev",
    "schema": "node compiler/LO.js schema examples/api-orders.lo --type CreateOrderRequest",
    "openapi": "node compiler/LO.js openapi examples/api-orders.lo",
    "verify": "node compiler/LO.js verify build/examples",
    "targets": "node compiler/LO.js targets examples",
    "ai-context": "node compiler/LO.js ai-context examples --out build/examples"
  },
  "engines": {
    "node": ">=18"
  }
}